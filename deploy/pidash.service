[Unit]
Description=pidash - Pi-hole dashboard manager
After=network.target

[Service]
User=pidash
Group=pidash
WorkingDirectory=/home/pidash/pidash
Environment=PIDASH_CONFIG=/home/pidash/pidash/config.json
ExecStart=/home/pidash/pidash/.venv/bin/gunicorn -w 4 -b 127.0.0.1:8080 --access-logfile - --error-logfile - wsgi:app
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
